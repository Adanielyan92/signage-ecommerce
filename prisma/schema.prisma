generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String?
  image        String?
  phone        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  orders       Order[]
  cartItems    CartItem[]
  savedDesigns SavedDesign[]
  addresses    Address[]
  accounts     Account[]
  sessions     Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Products ────────────────────────────────────

model Product {
  id          String          @id @default(cuid())
  slug        String          @unique
  name        String
  description String?
  category    ProductCategory
  imageUrl    String?
  isActive    Boolean         @default(true)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  pricingParams ProductPricingParams?
  options       ProductOptionDef[]
  orderItems    OrderItem[]
  cartItems     CartItem[]
  savedDesigns  SavedDesign[]
}

enum ProductCategory {
  CHANNEL_LETTERS
  DIMENSIONAL_LETTERS
  BANNERS
  PRINTS
  ACCESSORIES
}

model ProductPricingParams {
  id                    String @id @default(cuid())
  productId             String @unique
  calculationType       String
  basePricePerInch      Float
  largeSizeThreshold    Float?
  largeSizePricePerInch Float?
  minHeightForPrice     Float?
  minOrderPrice         Float?

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductOptionDef {
  id             String  @id @default(cuid())
  productId      String
  optionKey      String
  label          String
  inputType      String
  defaultValue   String?
  possibleValues Json?
  dependsOn      Json?
  sortOrder      Int     @default(0)
  isRequired     Boolean @default(false)
  isReadonly     Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, optionKey])
}

// ─── Address ─────────────────────────────────────

model Address {
  id         String  @id @default(cuid())
  userId     String
  label      String?
  line1      String
  line2      String?
  city       String
  state      String
  postalCode String
  country    String  @default("US")
  isDefault  Boolean @default(false)

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders Order[]
}

// ─── Cart ────────────────────────────────────────

model CartItem {
  id            String   @id @default(cuid())
  userId        String
  productId     String
  configuration Json
  thumbnailUrl  String?
  quantity      Int      @default(1)
  unitPrice     Float
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ─── Orders ──────────────────────────────────────

model Order {
  id                String      @id @default(cuid())
  orderNumber       String      @unique
  userId            String
  shippingAddressId String?
  status            OrderStatus @default(PENDING)
  subtotal          Float
  tax               Float       @default(0)
  shippingCost      Float       @default(0)
  total             Float
  stripePaymentId   String?     @unique
  stripeSessionId   String?
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user            User       @relation(fields: [userId], references: [id])
  shippingAddress Address?   @relation(fields: [shippingAddressId], references: [id])
  items           OrderItem[]
}

enum OrderStatus {
  PENDING
  PAYMENT_RECEIVED
  IN_PRODUCTION
  SHIPPED
  DELIVERED
  CANCELLED
}

model OrderItem {
  id            String @id @default(cuid())
  orderId       String
  productId     String
  configuration Json
  thumbnailUrl  String?
  quantity      Int
  unitPrice     Float
  totalPrice    Float

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

// ─── Saved Designs ───────────────────────────────

model SavedDesign {
  id            String   @id @default(cuid())
  userId        String
  productId     String
  name          String
  configuration Json
  thumbnailUrl  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}
